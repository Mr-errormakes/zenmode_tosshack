<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    android:layout_margin="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Handle Bar -->
        <View
            android:id="@+id/handle_bar"
            android:layout_width="60dp"
            android:layout_height="4dp"
            android:background="#40FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Title row -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Bro, We're losing zen🥺"
            android:textSize="32sp"
            android:fontFamily="@font/cabinet_grotesk_bold"
            android:textColor="@color/white"
            android:lineHeight="38sp"
            android:layout_marginTop="24dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/iv_app_icon_glow"
            app:layout_constraintTop_toBottomOf="@id/handle_bar" />

        <!-- Red Bars -->
        <ImageView
            android:id="@+id/iv_app_icon_glow"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:alpha="0.8"
            android:src="@drawable/app_icon"
            app:layout_constraintBottom_toBottomOf="@id/tv_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_title"
            app:layout_constraintVertical_bias="0.0"/>

        <LinearLayout
            android:id="@+id/bars_container"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_title">

            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_doom_bar_red" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_doom_bar_red" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_doom_bar_red" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_doom_bar_red" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_doom_bar_red" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_doom_bar_red" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_doom_bar_red" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_doom_bar_red" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_doom_bar_red" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_doom_bar_red" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_doom_bar_red" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_subtitle_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zenmode kidnapped by scrolls"
            android:textSize="22sp"
            android:fontFamily="@font/cabinet_grotesk_medium"
            android:textColor="#E0E0E0"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/bars_container" />

        <TextView
            android:id="@+id/tv_subtitle_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="15 minutes in life spent!"
            android:textSize="24sp"
            android:fontFamily="@font/cabinet_grotesk_bold"
            android:textColor="@color/white"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle_1" />

        <TextView
            android:id="@+id/tv_body_quote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="“Bro, we’ve doom-scrolled enough dinosaurs to extinction. close me, reclaim your life!”"
            android:textSize="18sp"
            android:fontFamily="@font/cabinet_grotesk_regular"
            android:textColor="#B0B0B0"
            android:alpha="0.8"
            android:lineHeight="26sp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle_2" />

        <!-- Feedback Question -->
        <TextView
            android:id="@+id/tv_feedback_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Was this scrolling session mindful?"
            android:textSize="16sp"
            android:fontFamily="@font/cabinet_grotesk_medium"
            android:textColor="#A3A3A3"
            android:gravity="center"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_body_quote" />

        <LinearLayout
            android:id="@+id/feedback_buttons_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_feedback_title">

            <Button
                android:id="@+id/btn_feedback_mindful"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intentional 👍"
                android:backgroundTint="#B9E234"
                android:textColor="#000000"
                android:fontFamily="@font/cabinet_grotesk_bold"
                android:layout_marginEnd="16dp" />

            <Button
                android:id="@+id/btn_feedback_regret"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Regretted 👎"
                android:backgroundTint="#F16351"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/cabinet_grotesk_bold" />

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:id="@+id/actions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/feedback_buttons_container">

            <Button
                android:id="@+id/btn_close_app"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Close App &amp; Reclaim Zen"
                android:backgroundTint="#00C700"
                android:textColor="#000000"
                android:textSize="16sp"
                android:fontFamily="@font/cabinet_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_snooze_5m"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Just 5 more minutes"
                android:backgroundTint="#252525"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="@font/cabinet_grotesk_medium"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/btn_snooze_4h"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                 android:text="Ignore alert for next 4 hours"
                android:textColor="#A3A3A3"
                android:textSize="12sp"
                android:fontFamily="@font/cabinet_grotesk_regular"
                android:padding="8dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
